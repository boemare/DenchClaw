%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px" } } }%%
flowchart TD

    %% ── Entry ──────────────────────────────────────────────
    subgraph CLI["CLI Layer"]
        ENTRY["denchclaw.mjs\nBootstrap Loader"]
        MAIN["entry.ts\nMain Entry"]
        RUNNER["run-main.ts\nCLI Runtime"]
        CMDREG["Command Registry\nCommander.js"]

        ENTRY --> MAIN
        MAIN -->|"normalize env,\nparse profile"| RUNNER
        RUNNER -->|"build program"| CMDREG
    end

    subgraph COMMANDS["CLI Commands"]
        BOOT["bootstrap\nOnboarding Wizard"]
        UPDATE["update\nUpdate Runtime"]
        START["start / stop\nrestart"]
        TELEM_CMD["telemetry\nenable / disable"]
        DELEGATE["Delegate to\nGlobal OpenClaw"]

        CMDREG --> BOOT
        CMDREG --> UPDATE
        CMDREG --> START
        CMDREG --> TELEM_CMD
        CMDREG -->|"non-core cmds"| DELEGATE
    end

    %% ── Web Application ───────────────────────────────────
    subgraph WEB["Web Application · Next.js 15"]
        direction TB
        WEBRT["Web Runtime\nManager"]
        SERVER["Standalone\nNode Server"]
        APIROUTES["API Routes"]
        UI["React 19 UI"]

        WEBRT -->|"install & spawn"| SERVER
        SERVER --> APIROUTES
        SERVER --> UI
    end

    subgraph WEBAPI["Web API Routes"]
        CHAT_API["Chat"]
        WORKSPACE_API["Workspace"]
        TERMINAL_API["Terminal\nxterm + pty"]
        SESSIONS_API["Sessions"]
        SKILLS_API["Skills Registry"]
        APPS_API["App Builder"]
        GATEWAY_API["Gateway Proxy"]
        MEMORIES_API["Memories"]
    end

    subgraph WEBUI["Web UI Components"]
        CHATUI["Chat Interface\nVercel AI SDK"]
        EDITOR["Tiptap\nRich Text Editor"]
        TABLES["TanStack Tables\nData Grid"]
        MONACOUI["Monaco Editor\nCode Editing"]
        CHARTS["Recharts\nVisualizations"]
        DND["Drag & Drop\ndnd-kit"]
    end

    APIROUTES --> WEBAPI
    UI --> WEBUI

    %% ── Skills ─────────────────────────────────────────────
    subgraph SKILLS["Skills · Pluggable Modules"]
        direction TB
        EVENTBRITE["Eventbrite\nEvent Management"]
        RETELL["Retell AI\nDual Voice Agents"]
        AGENTMAIL["AgentMail\nEmail Inbox"]
        ORCHESTRATION["Event\nOrchestration"]
        CRM["CRM / Database\nDuckDB"]
        BROWSER["Browser\nAutomation"]
        APPBUILDER["App Builder\nWorkspace Apps"]
        PRIVACY["Privacy Layer\nPII Protection"]
    end

    %% ── Extensions ─────────────────────────────────────────
    subgraph EXTENSIONS["Extensions · Platform Plugins"]
        AIGATEWAY["Dench AI Gateway\nModel Provider"]
        IDENTITY["Dench Identity\nAuthentication"]
        POSTHOG["PostHog Analytics\nProduct Analytics"]
    end

    %% ── Core Services ──────────────────────────────────────
    subgraph CORE["Core Services"]
        LOGGING["Logging\ntslog + rollover"]
        TELEMETRY["Telemetry\nClient"]
        CONFIG["Config & Paths\n~/.openclaw-dench"]
        PROCESS["Process Mgmt\nSignal Bridge"]
        INFRA["Infra Utils\nRuntime Guard"]
        TERMINAL_MOD["Terminal Theme\nEve Palette"]
    end

    %% ── External Services ──────────────────────────────────
    subgraph EXTERNAL["External Services"]
        EVENTBRITE_API["Eventbrite API"]
        RETELL_API["Retell AI API"]
        AGENTMAIL_API["AgentMail API"]
        OPENCLAW["OpenClaw\nAgent Platform"]
    end

    %% ── Storage ────────────────────────────────────────────
    subgraph STORAGE["Local Storage"]
        DUCKDB[("DuckDB\nWorkspace Data")]
        JSONCONF[("JSON Config\nopenclaw.json")]
        OAUTH[("OAuth Creds\ncredentials/")]
        LOGS[("Rolling Logs\n*.log")]
        MARKDOWN[("Knowledge Tree\nMarkdown Docs")]
        CHATSESSIONS[("Chat Sessions\nJSONL Transcripts")]
    end

    %% ── Infrastructure ─────────────────────────────────────
    subgraph INFRA_CI["Infrastructure & CI/CD"]
        GHA["GitHub Actions\nRelease Workflow"]
        NPM["npm Registry\neveevent"]
        LAUNCHD["macOS launchd\nDaemon"]
        DOCKER["Docker Support\nDaemonless Mode"]
        INTEGRATION_TESTS["Integration Tests\ntest-integrations.sh"]
    end

    %% ── Relationships ──────────────────────────────────────

    %% CLI → Web
    BOOT -->|"seed workspace\n& install app"| WEBRT
    START -->|"lifecycle\ncontrol"| WEBRT
    UPDATE -->|"reinstall\nstandalone"| WEBRT

    %% CLI → Core
    BOOT --> CONFIG
    RUNNER --> LOGGING
    RUNNER --> TELEMETRY
    RUNNER --> INFRA
    BOOT -->|"model selection"| AIGATEWAY

    %% CLI → External
    DELEGATE -->|"spawn CLI"| OPENCLAW

    %% Web → Skills
    SKILLS_API -->|"invoke"| SKILLS

    %% Web → Storage
    WORKSPACE_API --> DUCKDB
    MEMORIES_API --> MARKDOWN
    GATEWAY_API -->|"proxy"| AIGATEWAY

    %% Skills → External APIs
    EVENTBRITE -->|"REST"| EVENTBRITE_API
    RETELL -->|"REST"| RETELL_API
    AGENTMAIL -->|"REST"| AGENTMAIL_API
    ORCHESTRATION --> EVENTBRITE
    ORCHESTRATION --> RETELL
    ORCHESTRATION --> AGENTMAIL
    ORCHESTRATION --> BROWSER
    CRM --> DUCKDB

    %% Skills → Storage
    RETELL -->|"transcripts"| CHATSESSIONS
    AGENTMAIL -->|"email threads"| CHATSESSIONS

    %% Extensions
    TELEMETRY --> POSTHOG

    %% Core → Storage
    CONFIG --> JSONCONF
    CONFIG --> OAUTH
    LOGGING --> LOGS

    %% Infra/CI
    GHA -->|"publish"| NPM
    WEBRT -->|"register"| LAUNCHD
    INTEGRATION_TESTS -->|"verify"| RETELL_API
    INTEGRATION_TESTS -->|"verify"| AGENTMAIL_API
    INTEGRATION_TESTS -->|"verify"| EVENTBRITE_API

    %% ══════════════════════════════════════════════════════
    %% Retell AI Agent Architectures
    %% ══════════════════════════════════════════════════════

    %% ── Discovery Agent ──────────────────────────────────
    subgraph DISCOVERY_AGENT["Retell Discovery Agent · venue-discovery.json"]
        direction LR
        D_GREET["Greeting\n·static·\nIntroduce Eve\n& organization"]
        D_AVAIL["Check\nAvailability\nDate, headcount,\nalternatives"]
        D_PRICE["Pricing &\nDetails\nCost, minimums,\ninclusions"]
        D_CATER["Catering &\nDeposit\nIn-house, outside,\ndeposit terms"]
        D_LOGIS["Logistics\nPrivate/shared,\nsetup, access,\nparking"]
        D_WRAP["Wrap Up\nGet contact info\nfor follow-up"]
        D_NOAVAIL["No Availability\nAsk for referrals\nto similar venues"]
        D_END["End Call"]

        D_GREET -->|"venue responds"| D_AVAIL
        D_AVAIL -->|"available or\nalternatives"| D_PRICE
        D_AVAIL -->|"not available,\nno alternatives"| D_NOAVAIL
        D_PRICE -->|"got pricing"| D_CATER
        D_CATER -->|"got catering &\ndeposit info"| D_LOGIS
        D_LOGIS -->|"got logistics"| D_WRAP
        D_WRAP -->|"got contact"| D_END
        D_NOAVAIL -->|"ending"| D_END
    end

    %% ── Booking Agent ────────────────────────────────────
    subgraph BOOKING_AGENT["Retell Booking Agent · venue-booking.json"]
        direction LR
        B_GREET["Greeting\n·static·\nCall back to\nconfirm booking"]
        B_CONFIRM["Confirm Date\n& Price\nVerify terms\nunchanged"]
        B_DEPOSIT["Deposit &\nPayment\nRequest invoice,\nno card on phone"]
        B_TIMING["Confirm\nTiming\nSetup, event hours,\nbooking ref"]
        B_FINAL["Final\nWrap Up\nPaperwork,\ncancellation policy"]
        B_CHANGED["Terms\nChanged\nEscalate to team,\ndo NOT commit"]
        B_END["End Call"]

        B_GREET -->|"venue responds"| B_CONFIRM
        B_CONFIRM -->|"terms confirmed"| B_DEPOSIT
        B_CONFIRM -->|"price or date\nchanged"| B_CHANGED
        B_DEPOSIT -->|"payment info\nobtained"| B_TIMING
        B_TIMING -->|"timing\nconfirmed"| B_FINAL
        B_FINAL -->|"ready to end"| B_END
        B_CHANGED -->|"ending"| B_END
    end

    %% ── Agent link to skill ──────────────────────────────
    RETELL -->|"Discovery Agent\nvenue_name, event_date,\nheadcount, budget"| DISCOVERY_AGENT
    RETELL -->|"Booking Agent\nagreed_price, setup_time,\nevent_start, event_end"| BOOKING_AGENT

